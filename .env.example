# ── AnyIP.io credentials ───────────────────────────────────
ANYIP_USERNAME=user_XXXX
ANYIP_PASSWORD=YOUR_ANYIP_PASSWORD

# ── Proxy type: mobile | residential | both ─────────────────
ANYIP_PROXY_TYPE=mobile

# ── Sticky session TTL in minutes ───────────────────────────
# 4320 = 3 days  |  10080 = 7 days (max)
ANYIP_SESSION_MINUTES=4320

# ── Optional geo-targeting ───────────────────────────────────
# Leave blank for any location
ANYIP_COUNTRY=
ANYIP_CITY=

# ── Session mode ─────────────────────────────────────────────
# sticky   = same exit IP per client (default)
# rotating = fresh IP on every request
ANYIP_SESSION_MODE=sticky

# ── Prevent same IP across sessions (true/false) ────────────
ANYIP_STRICT_COLLISION=false

# ── Keep same peer when its IP goes offline (true/false) ─────
# false → sessreplace_false: error on peer drop instead of auto-rotate
ANYIP_SESSION_REPLACE=true

# ── Enforce same ISP/ASN on peer replacement (true/false) ────
ANYIP_SESSION_ASN_STRICT=false

# ── anyip.io Change IP URL (optional, from Dashboard) ────────
# ANYIP_PROXY_ID=
# ANYIP_INVALIDATE_HASH=

# ── Auto-rotate + retry on 407 from anyip.io (true/false) ───
AUTO_ROTATE_ON_ERROR=true

# ── Session ID header name ────────────────────────────────────
# Clients behind NAT send this to get independent sticky sessions
SESSION_ID_HEADER=X-Session-ID

# ── DNS cache TTL (seconds) ───────────────────────────────────
DNS_TTL=300

# ── Random secret for session hashing — CHANGE THIS ─────────
ANYIP_SESSION_SALT=replace-with-random-secret

# ── Logging: debug | info | warn | error ────────────────────
LOG_LEVEL=info
