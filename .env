# ── AnyIP.io credentials ───────────────────────────────────
ANYIP_USERNAME=user_b39840
ANYIP_PASSWORD=4e6dd0

# ── Proxy type: mobile | residential | both ─────────────────
ANYIP_PROXY_TYPE=mobile

# ── Sticky session TTL in minutes ───────────────────────────
# 4320 = 3 days  |  10080 = 7 days (max)
ANYIP_SESSION_MINUTES=4320

# ── Optional geo-targeting ───────────────────────────────────
# Leave blank for any location
ANYIP_COUNTRY=MY
ANYIP_CITY=

# ── Session mode ─────────────────────────────────────────────
# sticky   = same exit IP per client (default)
# rotating = fresh IP on every request (no session flag sent)
ANYIP_SESSION_MODE=sticky

# ── Prevent same IP across sessions (true/false) ────────────
# sessipcollision_strict — unique exit IPs for every session
ANYIP_STRICT_COLLISION=true

# ── When a sticky peer goes offline (true/false) ─────────────
# true  = auto-assign a new peer (default)
# false = return peer_not_found error instead
ANYIP_SESSION_REPLACE=true

# ── Enforce same ISP/ASN when peer is replaced (true/false) ──
ANYIP_SESSION_ASN_STRICT=false

# ── anyip.io Change IP URL credentials (optional) ────────────
# Found in Dashboard → Proxies → Get Proxy Details
# If set, /_rotate will also call anyip.io's API immediately
# ANYIP_PROXY_ID=
# ANYIP_INVALIDATE_HASH=

# ── Random secret for session hashing — CHANGE THIS ─────────
ANYIP_SESSION_SALT=this-is-random-secret

# ── Logging: debug | info | warn | error ────────────────────
LOG_LEVEL=debug

# ── Auto-rotate session on 407 from anyip.io (true/false) ────
# On 407 the session is rotated and the request retried silently
AUTO_ROTATE_ON_ERROR=true

# ── Session ID header (override IP-based session key) ─────────
# Clients behind NAT can send this header with a unique value
# to get their own independent sticky session
SESSION_ID_HEADER=X-Session-ID

# ── DNS cache TTL in seconds (default: 5 minutes) ────────────
DNS_TTL=300

# ── Worker processes (default: number of CPU cores) ──────────
# PROXY_WORKERS=1

# ── Max concurrent connections from a single client IP ───────
# NOTE: this limit is per-worker-process.
# Effective global limit = MAX_CONNS_PER_IP × PROXY_WORKERS
# MAX_CONNS_PER_IP=50
